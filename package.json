{
  "name": "rudex",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:42VN-Pasila/rudex.git",
  "author": "Kha Tieu",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf ./dist/ ./src/gen/",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint './**/*.ts' --quiet",
    "test": "NODE_ENV=test jest --config ./jest.config.js --setupFiles dotenv/config --forceExit",
    "test:e2e": "NODE_ENV=test jest --config ./jest-e2e.config.js --setupFiles dotenv/config --runInBand --forceExit",
    "typecheck": "yarn gen && yarn tsc --noEmit",
    "dev": "NODE_ENV=development ts-node -r tsconfig-paths/register src/server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "gen": "yarn gen:openapi",
    "gen:openapi": "openapi-typescript docs/openapi.yml --output src/gen/server.d.ts",
    "gen:db": "DATABASE_URL=postgresql://director:password@localhost:12001/director_dev kysely-codegen --dialect postgres --out-file src/schema.ts && prettier --write src/schema.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:down:volumes": "docker compose down -v",
    "migrate:latest": "NODE_ENV=development knex --knexfile ./knexfile.ts migrate:latest",
    "migrate:rollback": "NODE_ENV=development knex --knexfile ./knexfile.ts migrate:rollback",
    "migrate:make": "NODE_ENV=development knex --knexfile ./knexfile.ts migrate:make",
    "migrate:status": "NODE_ENV=development knex --knexfile ./knexfile.ts migrate:status",
    "setup:env": "node scripts/setup-env.js dev",
    "setup:prod": "NODE_ENV=production yarn setup:env && yarn clean && yarn gen && yarn build && yarn migrate:latest",
    "setup:dev": "NODE_ENV=development yarn setup:env && yarn clean && yarn gen && yarn build && yarn migrate:latest",
    "setup:test": "NODE_ENV=test yarn setup:env && yarn clean && yarn gen && yarn build && yarn migrate:latest"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "argon2": "^0.44.0",
    "bull": "^4.16.5",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "kysely": "^0.27.6",
    "pg": "^8.17.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@openapitools/openapi-generator-cli": "^2.25.0",
    "@types/bull": "^4.10.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "kysely-codegen": "^0.18.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.11",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
